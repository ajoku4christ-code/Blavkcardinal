# ==============================================
# SECURITY CONFIGURATION
# ==============================================
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to version control!

# ==============================================
# DATABASE SECURITY
# ==============================================
# Database connection string (use environment-specific values)
DATABASE_URL=file:./party.db

# ==============================================
# AUTHENTICATION & SESSION
# ==============================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-generated-secret-key-min-32-chars

# JWT secrets (generate separate keys for each environment)
JWT_SECRET=your-jwt-secret-key-min-32-characters
JWT_REFRESH_SECRET=your-refresh-token-secret

# ==============================================
# ENCRYPTION KEYS
# ==============================================
# AES-256 encryption key for sensitive data
ENCRYPTION_KEY=your-32-character-encryption-key
ENCRYPTION_IV_LENGTH=16

# ==============================================
# API SECURITY
# ==============================================
# Allowed origins (comma-separated for production)
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.vercel.app

# Trusted proxies (comma-separated IPs)
TRUSTED_PROXIES=127.0.0.1

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==============================================
# SMTP / EMAIL SECURITY
# ==============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM="Exclusive House Party" <noreply@yourdomain.com>

# ==============================================
# REDIS / BULLMQ (for background jobs)
# ==============================================
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# ==============================================
# ADMIN SECURITY
# ==============================================
# Comma-separated admin email addresses
ADMIN_EMAILS=admin@yourdomain.com,support@yourdomain.com

# Admin password (change immediately after first login!)
# Default: admin123 (CHANGE IN PRODUCTION!)

# ==============================================
# STRIPE PAYMENT SECURITY (if using)
# ==============================================
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# ==============================================
# APPLICATION URLs
# ==============================================
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app
APP_URL=https://your-domain.vercel.app

# ==============================================
# LOGGING & MONITORING
# ==============================================
LOG_LEVEL=info
LOG_SENSITIVE_DATA=false

# ==============================================
# SECURITY HEADERS
# ==============================================
# HSTS max age in seconds (1 year = 31536000)
HSTS_MAX_AGE=31536000

# ==============================================
# FILE UPLOAD LIMITS
# ==============================================
MAX_UPLOAD_SIZE_MB=5
ALLOWED_FILE_EXTENSIONS=jpg,jpeg,png,gif,pdf
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf
